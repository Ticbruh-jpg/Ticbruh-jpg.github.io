<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="LedgerStone & Associates — Precise bookkeeping and financial clarity for growing businesses in Bristol and beyond." />
  <title>LedgerStone & Associates — Bookkeeping & Financial Clarity</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="style.css" />
</head>
<body>

  <!-- Skip to content -->
  <a href="#main-content" class="skip-link">Skip to content</a>

  <!-- Book Opening Animation Overlay -->
  <div id="book-overlay" role="presentation" aria-hidden="true">
    <div class="book-scene">
      <div class="book">
        <!-- Book back / pages -->
        <div class="book-pages"></div>
        <!-- Spine -->
        <div class="book-spine"></div>
        <!-- Front cover -->
        <div class="book-cover">
          <div class="book-title">
            <div class="book-emblem">⚖</div>
            <div class="book-title-divider"></div>
            <div class="book-title-main">LedgerStone<br>&amp; Associates</div>
            <div class="book-title-divider"></div>
            <div class="book-title-sub">Est. 2012 · Bristol</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== HEADER ========== -->
  <header class="site-header" role="banner">
    <div class="header-inner">
      <a href="index.html" class="site-logo" aria-label="LedgerStone & Associates — Home">
        <span class="logo-name">Ledger<span>Stone</span> &amp; Associates</span>
        <span class="logo-tag">Bookkeeping &amp; Financial Services</span>
      </a>

      <button class="nav-toggle" aria-expanded="false" aria-controls="main-nav" aria-label="Toggle navigation menu">
        <span></span><span></span><span></span>
      </button>

      <nav class="site-nav" id="main-nav" aria-label="Main navigation">
        <ul>
          <li><a href="index.html">Home</a></li>
          <li><a href="about.html">About Us</a></li>
          <li><a href="services.html">Services</a></li>
          <li><a href="contact.html">Contact</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <!-- ========== MAIN ========== -->
  <main id="main-content" class="page-content">

    <!-- HERO -->
    <section class="hero hero--home" aria-labelledby="hero-title">
      <div class="hero__lines" aria-hidden="true"></div>
      <div class="hero__inner">
        <p class="hero__eyebrow">Bookkeeping · Financial Reporting · Tax Support</p>
        <h1 class="hero__title" id="hero-title">
          LedgerStone<br>
          <em>&amp; Associates</em>
        </h1>
        <p class="hero__tagline">Every Number Tells a Story.</p>
        <p class="hero__sub">Precise bookkeeping and financial clarity for growing businesses.</p>
        <div class="hero__ctas">
          <a href="contact.html" class="btn btn--primary">Get in Touch</a>
          <a href="about.html" class="btn btn--outline">Learn More</a>
        </div>
      </div>
    </section>

    <!-- SERVICES PREVIEW -->
    <section class="section section--light" aria-labelledby="services-preview-title">
      <div class="section__inner">
        <div class="section__header">
          <span class="section__eyebrow">What We Do</span>
          <h2 class="section__title" id="services-preview-title">Expert Financial Services</h2>
          <p class="section__lead">We handle the numbers so you can focus on what you do best — growing your business.</p>
          <hr class="divider-gold" />
        </div>

        <div class="cards-grid">
          <article class="service-card reveal stagger-1" aria-label="Monthly Bookkeeping service">
            <div class="service-card__icon" aria-hidden="true">📒</div>
            <h3 class="service-card__title">Monthly Bookkeeping</h3>
            <p class="service-card__desc">Accurate, timely recording of all your financial transactions. We reconcile accounts and keep your books spotless month after month.</p>
            <a href="services.html" class="service-card__link">Learn more</a>
          </article>

          <article class="service-card reveal stagger-2" aria-label="Financial Reporting service">
            <div class="service-card__icon" aria-hidden="true">📊</div>
            <h3 class="service-card__title">Financial Reporting</h3>
            <p class="service-card__desc">Clear, actionable profit &amp; loss statements, balance sheets, and cash flow reports that give you a true picture of your business health.</p>
            <a href="services.html" class="service-card__link">Learn more</a>
          </article>

          <article class="service-card reveal stagger-3" aria-label="Tax Preparation Support service">
            <div class="service-card__icon" aria-hidden="true">📋</div>
            <h3 class="service-card__title">Tax Preparation Support</h3>
            <p class="service-card__desc">We prepare and organise all records your accountant needs, ensuring on-time, accurate filing every single year without the scramble.</p>
            <a href="services.html" class="service-card__link">Learn more</a>
          </article>
        </div>
      </div>
    </section>

    <!-- STATS BAR -->
    <section class="stats-bar" aria-label="Company statistics">
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-number" data-count="500+" aria-label="500 or more clients served">0</span>
          <span class="stat-label">Clients Served</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-count="12" aria-label="12 years in business">0</span>
          <span class="stat-label">Years in Business</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-count="100%" aria-label="100 percent on-time filing record">0</span>
          <span class="stat-label">On-Time Filing Record</span>
        </div>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="section section--dark" aria-labelledby="testimonials-title">
      <div class="section__inner">
        <div class="section__header">
          <span class="section__eyebrow">Client Voices</span>
          <h2 class="section__title" id="testimonials-title">What Our Clients Say</h2>
          <hr class="divider-gold" />
        </div>

        <div class="testimonials-grid">
          <article class="testimonial-card reveal" aria-label="Testimonial from Sarah Chen">
            <div class="testimonial-card__quote" aria-hidden="true">"</div>
            <p class="testimonial-card__text">LedgerStone transformed our financial visibility overnight. We finally understand our cash position and can plan with confidence. Absolutely indispensable.</p>
            <div class="testimonial-card__author">
              <div class="testimonial-card__avatar">
                <img src="https://ui-avatars.com/api/?name=Sarah+Chen&background=7a4f2e&color=f5f0e8&size=80" alt="Sarah Chen" loading="lazy" width="40" height="40" />
              </div>
              <div>
                <span class="testimonial-card__name">Sarah Chen</span>
                <span class="testimonial-card__role">Director, Bloom Interiors Ltd</span>
              </div>
            </div>
          </article>

          <article class="testimonial-card reveal" aria-label="Testimonial from Marcus Webb">
            <div class="testimonial-card__quote" aria-hidden="true">"</div>
            <p class="testimonial-card__text">Three years in and I've never missed a tax deadline. The team is responsive, thorough, and genuinely cares about getting things right. Highly recommend.</p>
            <div class="testimonial-card__author">
              <div class="testimonial-card__avatar">
                <img src="https://ui-avatars.com/api/?name=Marcus+Webb&background=7a4f2e&color=f5f0e8&size=80" alt="Marcus Webb" loading="lazy" width="40" height="40" />
              </div>
              <div>
                <span class="testimonial-card__name">Marcus Webb</span>
                <span class="testimonial-card__role">Owner, Webb &amp; Sons Carpentry</span>
              </div>
            </div>
          </article>

          <article class="testimonial-card reveal" aria-label="Testimonial from Fatima Osei">
            <div class="testimonial-card__quote" aria-hidden="true">"</div>
            <p class="testimonial-card__text">Switching to LedgerStone was the best business decision I made last year. Clean books, clear reports, and I can actually understand my own finances now.</p>
            <div class="testimonial-card__author">
              <div class="testimonial-card__avatar">
                <img src="https://ui-avatars.com/api/?name=Fatima+Osei&background=7a4f2e&color=f5f0e8&size=80" alt="Fatima Osei" loading="lazy" width="40" height="40" />
              </div>
              <div>
                <span class="testimonial-card__name">Fatima Osei</span>
                <span class="testimonial-card__role">Founder, Kente Kitchen</span>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- FOOTER CTA BAND -->
    <section class="cta-band" aria-labelledby="cta-title">
      <div class="cta-band__inner">
        <h2 class="cta-band__title" id="cta-title">Ready to Get Your Books in Order?</h2>
        <p class="cta-band__sub">Let's build the financial clarity your business deserves. Our first conversation is always free.</p>
        <a href="contact.html" class="btn btn--primary">Contact Us Today</a>
      </div>
    </section>

  </main>

  <!-- ========== FOOTER ========== -->
  <footer class="site-footer" role="contentinfo">
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand">
          <div class="footer-brand-name">Ledger<span>Stone</span> &amp; Associates</div>
          <div class="footer-tagline">Every Number Tells a Story.</div>
          <div class="footer-contact-info">
            <p>42 Fernwood Lane, Suite 3<br>Bristol BS1 4AB, United Kingdom</p>
            <p><a href="tel:+441170001234">+44 117 000 1234</a></p>
            <p><a href="mailto:hello@ledgerstone.co">hello@ledgerstone.co</a></p>
          </div>
        </div>
        <nav class="footer-nav" aria-label="Footer navigation">
          <span class="footer-nav-title">Navigate</span>
          <a href="index.html">Home</a>
          <a href="about.html">About Us</a>
          <a href="services.html">Services</a>
          <a href="contact.html">Contact</a>
        </nav>
      </div>
      <div class="footer-bottom">
        <p class="footer-copy">&copy; <span id="footer-year">2024</span> LedgerStone &amp; Associates. All rights reserved.</p>
        <p class="footer-copy">Registered in England &amp; Wales</p>
      </div>
    </div>
  </footer>

  <script src="main.js"></script>
  <script>document.getElementById('footer-year').textContent = new Date().getFullYear();</script>
</body>
</html>
